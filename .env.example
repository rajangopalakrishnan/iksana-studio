# MongoDB connection for Vercel / local development
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/iksana?retryWrites=true&w=majority

# SMTP settings for email delivery
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
